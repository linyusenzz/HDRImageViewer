<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="HdrImageViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:HdrImageViewer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:HdrImageViewer.Pages"
    Title="HDR 图片查看器"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="WindowRoot">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="HDR 图片查看器"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            AutomationProperties.AutomationId="MainNavigationView"
            CompactPaneLength="48"
            IsBackButtonVisible="Collapsed"
            OpenPaneLength="280"
            IsPaneToggleButtonVisible="False"
            Loaded="NavView_Loaded"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    AutomationProperties.AutomationId="ViewerNavigationItem"
                    AutomationProperties.Name="查看器"
                    Content="查看器"
                    IsSelected="True"
                    Tag="viewer">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.AutomationId="AboutNavigationItem"
                    AutomationProperties.Name="关于"
                    Content="关于"
                    Tag="about">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA3A;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Grid>
                <pages:HomePage x:Name="ViewerPage" />
                <Frame
                    x:Name="NavFrame"
                    Visibility="Collapsed" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
